<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="py-5">
    <div class="container">

        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 p-md-5">

                        <div class="mb-4">
                            <h1 class="fw-bold mb-2">Edit Recipe</h1>
                            <p class="text-muted mb-0">
                                Update your recipe information below.
                            </p>
                        </div>

                        <form
                            action="/recipes/edit/<%= recipe.id %>"
                            method="POST"
                            enctype="multipart/form-data"
                        >

                            <div class="mb-3">
                                <label class="form-label">Title</label>

                                <input
                                    type="text"
                                    name="title"
                                    class="form-control"
                                    value="<%= recipe.title %>"
                                    required
                                >
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>

                                <textarea
                                    name="description"
                                    class="form-control"
                                    rows="4"
                                ><%= recipe.description %></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Ingredients</label>

                                <textarea
                                    name="ingredients"
                                    class="form-control"
                                    rows="6"
                                    required
                                ><%= recipe.ingredients %></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Instructions</label>

                                <textarea
                                    name="instructions"
                                    class="form-control"
                                    rows="7"
                                    required
                                ><%= recipe.instructions %></textarea>
                            </div>

                            <div class="row">

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Servings</label>

                                    <input
                                        type="number"
                                        name="servings"
                                        class="form-control"
                                        value="<%= recipe.servings %>"
                                        min="1"
                                    >
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Category</label>

                                    <select
                                        name="category"
                                        class="form-select"
                                    >
                                        <option value="breakfast" <%= recipe.category.toLowerCase() === "breakfast" ? "selected" : "" %>>
                                            Breakfast
                                        </option>

                                        <option value="lunch" <%= recipe.category.toLowerCase() === "lunch" ? "selected" : "" %>>
                                            Lunch
                                        </option>

                                        <option value="dinner" <%= recipe.category.toLowerCase() === "dinner" ? "selected" : "" %>>
                                            Dinner
                                        </option>

                                        <option value="dessert" <%= recipe.category.toLowerCase() === "dessert" ? "selected" : "" %>>
                                            Dessert
                                        </option>

                                        <option value="drinks" <%= recipe.category.toLowerCase() === "drinks" ? "selected" : "" %>>
                                            Drinks
                                        </option>

                                        <option value="snacks" <%= recipe.category.toLowerCase() === "snacks" ? "selected" : "" %>>
                                            Snacks
                                        </option>
                                    </select>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Difficulty</label>

                                    <select
                                        name="difficulty"
                                        class="form-select"
                                    >
                                        <option value="easy" <%= recipe.difficulty.toLowerCase() === "easy" ? "selected" : "" %>>
                                            Easy
                                        </option>

                                        <option value="medium" <%= recipe.difficulty.toLowerCase() === "medium" ? "selected" : "" %>>
                                            Medium
                                        </option>

                                        <option value="hard" <%= recipe.difficulty.toLowerCase() === "hard" ? "selected" : "" %>>
                                            Hard
                                        </option>
                                    </select>
                                </div>

                            </div>

                            <div class="mb-3">
                                <label class="form-label">
                                    Cooking Time (minutes)
                                </label>

                                <input
                                    type="number"
                                    name="cooking_time"
                                    class="form-control"
                                    value="<%= recipe.cooking_time %>"
                                    min="1"
                                    required
                                >
                            </div>

                            <div class="mb-4">
                                <label class="form-label">
                                    YouTube Tutorial Link
                                </label>

                                <input
                                    type="url"
                                    name="youtube_link"
                                    class="form-control"
                                    value="<%= recipe.youtube_link || "" %>"
                                    placeholder="https://www.youtube.com/watch?v=..."
                                >
                            </div>

                            <div class="mb-4">
                                <label class="form-label">
                                    Recipe Image
                                </label>

                                <% if (recipe.image) { %>

                                    <div class="mb-3">
                                        <p class="text-muted mb-2">
                                            Current image
                                        </p>

                                        <img
                                            src="/uploads/<%= recipe.image %>"
                                            alt="<%= recipe.title %>"
                                            class="img-fluid rounded"
                                            style="max-height: 280px; object-fit: cover;"
                                            onerror="this.onerror=null; this.src='/images/default-recipe.png';"
                                        >
                                    </div>

                                <% } %>

                                <input
                                    type="file"
                                    name="image"
                                    class="form-control"
                                    accept="image/*"
                                >

                                <small class="text-muted">
                                    Leave this empty to keep the current image.
                                </small>
                            </div>

                            <div class="d-flex flex-column flex-sm-row gap-2">

                                <button
                                    type="submit"
                                    class="btn btn-brown"
                                >
                                    Update Recipe
                                </button>

                                <a
                                    href="/recipes/<%= recipe.id %>"
                                    class="btn btn-outline-secondary"
                                >
                                    Cancel
                                </a>

                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </div>
</main>

<%- include("../partials/footer") %>