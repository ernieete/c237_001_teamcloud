<!DOCTYPE html>
<html>
<head>
    <title><%= recipe.title %></title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container mt-5">

    <!-- Recipe Information -->
    <div class="card p-4 mb-4">

        <h1 class="mb-3">
            <%= recipe.title %>
        </h1>

        <% if (recipe.image) { %>
            <img
                src="/uploads/<%= recipe.image %>"
                alt="<%= recipe.title %>"
                class="img-fluid mb-4"
            >
        <% } %>

        <p>
            <strong>Created by:</strong>
            <%= recipe.username %>
        </p>

        <p>
            <%= recipe.description %>
        </p>

        <h3>🥣 Ingredients</h3>

        <ul>
            <% recipe.ingredients.split(",").forEach(item => { %>
                <li><%= item.trim() %></li>
            <% }); %>
        </ul>

        <h3>Instructions</h3>

        <p>
            <%= recipe.instructions %>
        </p>

        <div class="mt-3">

            <span class="badge bg-secondary">
                🍽 <%= recipe.servings %> Servings
            </span>

            <span class="badge bg-secondary">
                🍛 <%= recipe.category %>
            </span>

            <span class="badge bg-secondary">
                ⭐ <%= recipe.difficulty %>
            </span>

            <span class="badge bg-secondary">
                ⏱ <%= recipe.cooking_time %> mins
            </span>

        </div>

    </div>


    <!-- ============================= -->
    <!-- RATING SECTION -->
    <!-- ============================= -->

    <div class="card p-4 mb-4">

        <h2>⭐ Ratings</h2>

        <h3>
            <%= averageRating %> / 5
        </h3>

        <p>
            Based on <%= totalRatings %> rating(s)
        </p>

        <!-- Rating Breakdown -->
        <h4>Rating Breakdown</h4>

        <%
            const breakdownMap = {};

            ratingBreakdown.forEach(item => {
                breakdownMap[item.rating] = item.total;
            });
        %>

        <% for (let star = 5; star >= 1; star--) { %>

            <p>
                <%= "⭐".repeat(star) %>
                <%= breakdownMap[star] || 0 %>
            </p>

        <% } %>


        <!-- Logged In User Rating -->
        <% if (currentUser) { %>

            <hr>

            <h4>
                <% if (userRating) { %>
                    Your Rating: <%= userRating %> / 5
                <% } else { %>
                    Give This Recipe a Rating
                <% } %>
            </h4>

            <% if (userRating) { %>

                <!-- Edit Rating -->
                <form action="/ratings/edit" method="POST" class="mb-2">

                    <input
                        type="hidden"
                        name="recipeId"
                        value="<%= recipe.id %>"
                    >

                    <select name="rating" class="form-select mb-2">

                        <option value="1" <%= userRating == 1 ? "selected" : "" %>>
                            ⭐ 1
                        </option>

                        <option value="2" <%= userRating == 2 ? "selected" : "" %>>
                            ⭐⭐ 2
                        </option>

                        <option value="3" <%= userRating == 3 ? "selected" : "" %>>
                            ⭐⭐⭐ 3
                        </option>

                        <option value="4" <%= userRating == 4 ? "selected" : "" %>>
                            ⭐⭐⭐⭐ 4
                        </option>

                        <option value="5" <%= userRating == 5 ? "selected" : "" %>>
                            ⭐⭐⭐⭐⭐ 5
                        </option>

                    </select>

                    <button class="btn btn-primary">
                        Update Rating
                    </button>

                </form>

                <!-- Delete Rating -->
                <form action="/ratings/delete" method="POST">

                    <input
                        type="hidden"
                        name="recipeId"
                        value="<%= recipe.id %>"
                    >

                    <button class="btn btn-danger">
                        Delete My Rating
                    </button>

                </form>

            <% } else { %>

                <!-- Add Rating -->
                <form action="/ratings/add" method="POST">

                    <input
                        type="hidden"
                        name="recipeId"
                        value="<%= recipe.id %>"
                    >

                    <select name="rating" class="form-select mb-2">

                        <option value="1">⭐ 1</option>
                        <option value="2">⭐⭐ 2</option>
                        <option value="3">⭐⭐⭐ 3</option>
                        <option value="4">⭐⭐⭐⭐ 4</option>
                        <option value="5">⭐⭐⭐⭐⭐ 5</option>

                    </select>

                    <button class="btn btn-success">
                        Submit Rating
                    </button>

                </form>

            <% } %>

        <% } else { %>

            <p>
                <a href="/login">Log in</a>
                to rate this recipe.
            </p>

        <% } %>

    </div>


    <!-- ============================= -->
    <!-- COMMENTS SECTION -->
    <!-- ============================= -->

    <div class="card p-4 mb-4">

        <h2>💬 Reviews & Comments</h2>

        <!-- Add Comment -->
        <% if (currentUser) { %>

            <form action="/comments/add" method="POST">

                <input
                    type="hidden"
                    name="recipeId"
                    value="<%= recipe.id %>"
                >

                <textarea
                    name="comment"
                    class="form-control mb-2"
                    placeholder="Write your comment..."
                    required
                ></textarea>

                <button class="btn btn-success">
                    Add Comment
                </button>

            </form>

        <% } else { %>

            <p>
                <a href="/login">Log in</a>
                to leave a comment.
            </p>

        <% } %>


        <hr>


        <!-- Display Comments -->
        <% if (comments.length === 0) { %>

            <p>
                No comments yet. Be the first to comment!
            </p>

        <% } else { %>

            <% comments.forEach(comment => { %>

                <div class="border rounded p-3 mb-3">

                    <strong>
                        <%= comment.username %>
                    </strong>

                    <small class="text-muted">
                        <%= new Date(comment.created_at).toLocaleString() %>
                    </small>

                    <p class="mt-2">
                        <%= comment.comment %>
                    </p>


                    <!-- Owner Edit -->
                    <% if (
                        currentUser &&
                        currentUser.id === comment.user_id
                    ) { %>

                        <form
                            action="/comments/edit"
                            method="POST"
                            class="mb-2"
                        >

                            <input
                                type="hidden"
                                name="commentId"
                                value="<%= comment.id %>"
                            >

                            <input
                                type="hidden"
                                name="recipeId"
                                value="<%= recipe.id %>"
                            >

                            <textarea
                                name="comment"
                                class="form-control mb-2"
                                required
                            ><%= comment.comment %></textarea>

                            <button class="btn btn-primary btn-sm">
                                Edit Comment
                            </button>

                        </form>

                    <% } %>


                    <!-- Owner or Admin Delete -->
                    <% if (
                        currentUser &&
                        (
                            currentUser.id === comment.user_id ||
                            currentUser.role === "admin"
                        )
                    ) { %>

                        <form
                            action="/comments/delete"
                            method="POST"
                        >

                            <input
                                type="hidden"
                                name="commentId"
                                value="<%= comment.id %>"
                            >

                            <input
                                type="hidden"
                                name="recipeId"
                                value="<%= recipe.id %>"
                            >

                            <button class="btn btn-danger btn-sm">
                                Delete Comment
                            </button>

                        </form>

                    <% } %>

                </div>

            <% }); %>

        <% } %>

    </div>


    <a href="/recipes" class="btn btn-secondary">
        ← Back to Recipes
    </a>

</div>

</body>
</html>