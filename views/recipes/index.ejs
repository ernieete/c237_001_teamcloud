<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="recipe-container">

    <div class="section-heading">

        <p class="section-label">
            COMMUNITY RECIPES
        </p>

        <h1 class="recipe-title">
            Explore Homemade Recipes
        </h1>

        <p>
            Discover delicious recipes shared by our community.
        </p>

    </div>

    <% if (recipes.length === 0) { %>

        <div class="recipe-card">
            <p>No recipes available.</p>
        </div>

    <% } else { %>

        <div class="recipe-grid">

            <% recipes.forEach(recipe => { %>

                <div class="recipe-card">

                    <% if (recipe.image) { %>

                        <img
                            src="/uploads/<%= recipe.image %>"
                            alt="<%= recipe.title %>"
                            class="recipe-grid-image"
                        >

                    <% } %>

                    <div class="recipe-card-content">

                        <h2><%= recipe.title %></h2>

                        <p class="recipe-author">
                            By <strong><%= recipe.username %></strong>
                        </p>

                        <div class="recipe-badges">

                            <span class="recipe-badge">
                                🍴 <%= recipe.category %>
                            </span>

                            <span class="recipe-badge">
                                ⭐ <%= recipe.difficulty %>
                            </span>

                            <span class="recipe-badge">
                                ⏱ <%= recipe.cooking_time %> mins
                            </span>

                        </div>

                        <a
                            href="/recipes/<%= recipe.id %>"
                            class="btn btn-brown w-100 mb-2"
                        >
                            View Recipe
                        </a>

                        <% if (user.role === "admin" || user.id === recipe.user_id) { %>

                            <a
                                href="/recipes/edit/<%= recipe.id %>"
                                class="btn btn-outline-secondary w-100 mb-2"
                            >
                                ✏ Edit Recipe
                            </a>

                            <form
                                action="/recipes/delete/<%= recipe.id %>"
                                method="POST"
                                onsubmit="return confirm('Are you sure you want to delete this recipe?');"
                            >

                                <button
                                    type="submit"
                                    class="btn btn-outline-danger w-100"
                                >
                                    🗑 Delete Recipe
                                </button>

                            </form>

                        <% } %>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</main>

<%- include("../partials/footer") %>