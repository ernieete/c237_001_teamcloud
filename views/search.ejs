<%- include("partials/header") %>
<%- include("partials/navbar") %>

<main class="discovery-page">

    <section class="discovery-hero">
        <div class="container">

            <p class="section-label">
                FIND YOUR NEXT DISH
            </p>

            <h1>Search Recipes</h1>

            <p>
                Search by recipe name or ingredient,
                then refine the results using filters.
            </p>

            <%- include(
                "partials/search-filter-bar",
                {
                    query: query,
                    filters: {}
                }
            ) %>

        </div>
    </section>

    <section class="discovery-results-section">
        <div class="container">

            <div class="discovery-results-heading">

                <div>
                    <p class="section-label">
                        SEARCH RESULTS
                    </p>

                    <h2>
                        <%= query
                            ? `Results for “${query}”`
                            : "Start by entering a search"
                        %>
                    </h2>
                </div>

                <% if (query) { %>
                    <span class="result-count">
                        <%= results.length %>
                        result<%= results.length === 1 ? "" : "s" %>
                    </span>
                <% } %>

            </div>

            <% if (!query) { %>

                <div class="discovery-empty-state">

                    <div class="empty-icon">
                        🔎
                    </div>

                    <h3>
                        What are you craving?
                    </h3>

                    <p>
                        Try searching for “chicken”,
                        “pasta” or an ingredient you already have.
                    </p>

                </div>

            <% } else if (results.length === 0) { %>

                <div class="discovery-empty-state">

                    <div class="empty-icon">
                        🥄
                    </div>

                    <h3>
                        No matching recipes
                    </h3>

                    <p>
                        Try another recipe name,
                        ingredient or a wider set of filters.
                    </p>

                    <a
                        href="/recipes"
                        class="btn btn-brown"
                    >
                        Browse All Recipes
                    </a>

                </div>

            <% } else { %>

                <div class="row g-4">

                    <% results.forEach(recipe => { %>

                        <div class="col-md-6 col-lg-4">

                            <%- include(
                                "partials/recipe-card",
                                { recipe }
                            ) %>

                        </div>

                    <% }) %>

                </div>

            <% } %>

        </div>
    </section>

</main>

<%- include("partials/footer") %>