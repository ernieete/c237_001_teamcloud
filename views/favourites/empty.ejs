<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>No Favourites Yet</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <!-- Navigation Bar -->
    <%- include('../partials/navbar') %>

    <div class="container py-5">

        <div class="row justify-content-center">

            <div class="col-lg-8 text-center">

                <!-- Illustration -->

                <img
                    src="/images/empty-favourites.png"
                    alt="No favourites"
                    class="img-fluid mb-4"
                    style="max-width:300px;">

                <!-- Heading -->

                <h1 class="fw-bold mb-3">

                    ❤️ No Favourites Yet

                </h1>

                <p class="lead text-muted">

                    You haven't saved any recipes yet.

                </p>

                <p class="text-muted">

                    Browse the homepage and click the <strong>heart</strong> icon on any recipe to add it to your favourites.
                    Once saved, your favourite recipes will appear here for quick access.

                </p>

                <!-- Buttons -->

                <div class="mt-4">

                    <a href="/" class="btn btn-primary btn-lg me-2">

                        Browse Recipes

                    </a>

                    <a href="/recipes/add" class="btn btn-outline-success btn-lg">

                        Create Recipe

                    </a>

                </div>

            </div>

        </div>

        <!-- Helpful Tips -->

        <div class="row mt-5">

            <div class="col-lg-8 mx-auto">

                <div class="card shadow-sm">

                    <div class="card-header bg-light">

                        <strong>What can you do?</strong>

                    </div>

                    <div class="card-body">

                        <ul class="list-group list-group-flush">

                            <li class="list-group-item">

                                ❤️ Save recipes you enjoy.

                            </li>

                            <li class="list-group-item">

                                📖 View all saved recipes in one place.

                            </li>

                            <li class="list-group-item">

                                📊 View statistics about your favourite recipes.

                            </li>

                            <li class="list-group-item">

                                ❌ Remove recipes from your favourites anytime.

                            </li>

                        </ul>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>