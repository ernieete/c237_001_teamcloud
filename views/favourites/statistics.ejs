<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Favourite Statistics</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include('../partials/navbar') %>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">
                📊 Favourite Statistics
            </h2>

            <p class="text-muted">
                View statistics about your saved recipes.
            </p>

        </div>

        <a href="/favourites" class="btn btn-outline-primary">
            ← Back to My Collection
        </a>

    </div>


    <!-- Statistic Cards -->

    <div class="row mb-4">

        <div class="col-md-3 mb-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h1 class="text-danger">

                        ❤️

                    </h1>

                    <h3>

                        <%= stats.totalFavourites %>

                    </h3>

                    <p class="text-muted mb-0">

                        Total Favourites

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h1>

                        🍳

                    </h1>

                    <h3>

                        <%= stats.recipesCreated %>

                    </h3>

                    <p class="text-muted mb-0">

                        Recipes Created

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h1>

                        ⭐

                    </h1>

                    <h5>

                        <% if(stats.latestFavourite){ %>

                            <%= new Date(stats.latestFavourite).toLocaleDateString() %>

                        <% } else { %>

                            N/A

                        <% } %>

                    </h5>

                    <p class="text-muted mb-0">

                        Latest Favourite

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card text-center shadow-sm">

                <div class="card-body">

                    <h1>

                        📅

                    </h1>

                    <h5>

                        <% if(stats.oldestFavourite){ %>

                            <%= new Date(stats.oldestFavourite).toLocaleDateString() %>

                        <% } else { %>

                            N/A

                        <% } %>

                    </h5>

                    <p class="text-muted mb-0">

                        First Favourite

                    </p>

                </div>

            </div>

        </div>

    </div>


    <!-- Favourite Categories -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-primary text-white">

            Favourite Categories

        </div>

        <div class="card-body">

            <% if(stats.favouriteCategories.length === 0){ %>

                <p class="text-muted">

                    No favourite recipes yet.

                </p>

            <% } else { %>

                <table class="table table-striped">

                    <thead>

                    <tr>

                        <th>Category</th>

                        <th>Total Recipes</th>

                    </tr>

                    </thead>

                    <tbody>

                    <% stats.favouriteCategories.forEach(category => { %>

                        <tr>

                            <td>

                                <%= category.category %>

                            </td>

                            <td>

                                <span class="badge bg-success">

                                    <%= category.total %>

                                </span>

                            </td>

                        </tr>

                    <% }) %>

                    </tbody>

                </table>

            <% } %>

        </div>

    </div>


    <!-- Recently Saved -->

    <div class="card shadow-sm">

        <div class="card-header bg-success text-white">

            Recently Saved Recipes

        </div>

        <div class="card-body">

            <% if(stats.recentFavourites.length === 0){ %>

                <p class="text-muted">

                    No recently saved recipes.

                </p>

            <% } else { %>

                <table class="table table-hover">

                    <thead>

                    <tr>

                        <th>Recipe</th>

                        <th>Category</th>

                        <th>Saved On</th>

                        <th></th>

                    </tr>

                    </thead>

                    <tbody>

                    <% stats.recentFavourites.forEach(recipe => { %>

                        <tr>

                            <td>

                                <%= recipe.title %>

                            </td>

                            <td>

                                <%= recipe.category %>

                            </td>

                            <td>

                                <%= new Date(recipe.favourite_date).toLocaleDateString() %>

                            </td>

                            <td>

                                <a
                                    href="/recipes/<%= recipe.recipe_id %>"
                                    class="btn btn-sm btn-primary">

                                    View

                                </a>

                            </td>

                        </tr>

                    <% }) %>

                    </tbody>

                </table>

            <% } %>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>