<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="page-section">
  <div class="container"><div class="form-card mx-auto">
    <h1>Create Account</h1><p class="text-muted">Join the Simply Homemade community.</p>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form method="POST" action="/register">
      <div class="mb-3"><label class="form-label">Username</label><input class="form-control" name="username" maxlength="50" value="<%= formData.username || '' %>" required></div>
      <div class="mb-3"><label class="form-label">Email</label><input class="form-control" type="email" name="email" value="<%= formData.email || '' %>" required></div>
      <div class="mb-3"><label class="form-label">Password</label><input class="form-control" type="password" name="password" minlength="8" required><div class="form-text">Use at least 8 characters.</div></div>
      <div class="mb-4"><label class="form-label">Confirm Password</label><input class="form-control" type="password" name="confirmPassword" minlength="8" required></div>
      <button class="btn btn-brown w-100" type="submit">Register</button>
    </form>
    <p class="text-center mt-3 mb-0">Already registered? <a href="/login">Log in here</a>.</p>
  </div></div>
</main>
<%- include('../partials/footer') %>
