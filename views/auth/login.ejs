<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="page-section">
  <div class="container"><div class="form-card mx-auto">
    <h1>Welcome Back</h1><p class="text-muted">Log in to manage your recipes and profile.</p>
    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form method="POST" action="/login">
      <div class="mb-3"><label class="form-label">Email</label><input class="form-control" type="email" name="email" value="<%= formData.email || '' %>" required></div>
      <div class="mb-4"><label class="form-label">Password</label><input class="form-control" type="password" name="password" required></div>
      <button class="btn btn-brown w-100" type="submit">Login</button>
    </form>
    <p class="text-center mt-3 mb-0">No account yet? <a href="/register">Register here</a>.</p>
  </div></div>
</main>
<%- include('../partials/footer') %>
