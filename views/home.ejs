<%- include("partials/header") %>
<%- include("partials/navbar") %>

<main>
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center min-vh-hero">
                <div class="col-lg-7">
                    <span class="hero-label">
                        Made with love, shared with everyone
                    </span>

                    <h1 class="hero-title">
                        Delicious recipes,
                        <span>simply homemade.</span>
                    </h1>

                    <p class="hero-description">
                        Discover recipes shared by home cooks,
                        save your favourites and share your own
                        creations with the community.
                    </p>

                    <div class="hero-actions">
                        <a
                            href="/recipes"
                            class="btn btn-brown btn-lg"
                        >
                            Explore Recipes
                        </a>

                        <% if (currentUser) { %>
                            <a
                                href="/recipes/add"
                                class="btn btn-light-custom btn-lg"
                            >
                                Share a Recipe
                            </a>
                        <% } else { %>
                            <a
                                href="/register"
                                class="btn btn-light-custom btn-lg"
                            >
                                Join Our Community
                            </a>
                        <% } %>
                    </div>
                </div>

                <div class="col-lg-5 text-center">
                    <div class="hero-food-card">
                        <div class="food-emoji">🍲</div>

                        <h3>Cook. Share. Enjoy.</h3>

                        <p>
                            Your next favourite recipe is just
                            one click away.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="feature-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">WHAT YOU CAN DO</p>
                <h2>Everything you need in one recipe space</h2>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">🔍</div>
                        <h3>Discover Recipes</h3>
                        <p>
                            Search and filter recipes by category,
                            difficulty, cooking time and rating.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">📝</div>
                        <h3>Share Your Cooking</h3>
                        <p>
                            Add ingredients, instructions and an
                            image to share your homemade recipe.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">❤️</div>
                        <h3>Save Your Favourites</h3>
                        <p>
                            Keep recipes that you love in your own
                            personal favourites collection.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="recipe-preview-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">COMING TOGETHER</p>
                <h2>Featured community recipes</h2>

                <p>
                    Recipes will appear here after your team
                    implements recipe management.
                </p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="placeholder-recipe-card">
                        <div class="placeholder-image">🥞</div>
                        <div class="placeholder-content">
                            <span>Breakfast</span>
                            <h3>Community Recipe</h3>
                            <p>Recipe details will be loaded from MySQL.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="placeholder-recipe-card">
                        <div class="placeholder-image">🍝</div>
                        <div class="placeholder-content">
                            <span>Dinner</span>
                            <h3>Community Recipe</h3>
                            <p>Recipe details will be loaded from MySQL.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="placeholder-recipe-card">
                        <div class="placeholder-image">🍰</div>
                        <div class="placeholder-content">
                            <span>Dessert</span>
                            <h3>Community Recipe</h3>
                            <p>Recipe details will be loaded from MySQL.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <a href="/recipes" class="btn btn-brown">
                    View All Recipes
                </a>
            </div>
        </div>
    </section>
</main>

<%- include("partials/footer") %>