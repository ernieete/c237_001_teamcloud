<%- include("partials/header") %>
<%- include("partials/navbar") %>

<main>
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center min-vh-hero">
                <div class="col-lg-7">
                    <span class="hero-label">
                        Made with love, shared with everyone
                    </span>

                    <h1 class="hero-title">
                        Delicious recipes,
                        <span>simply homemade.</span>
                    </h1>

                    <p class="hero-description">
                        Discover recipes shared by home cooks,
                        save your favourites and share your own
                        creations with the community.
                    </p>

                    <div class="hero-actions">
                        <a
                            href="/recipes"
                            class="btn btn-brown btn-lg"
                        >
                            Explore Recipes
                        </a>

                        <% if (currentUser) { %>
                            <a
                                href="/recipes/add"
                                class="btn btn-light-custom btn-lg"
                            >
                                Share a Recipe
                            </a>
                        <% } else { %>
                            <a
                                href="/register"
                                class="btn btn-light-custom btn-lg"
                            >
                                Join Our Community
                            </a>
                        <% } %>

                        <a
                            href="/ratings/highest"
                            class="btn btn-light-custom btn-lg"
                        >
                            ⭐ Highest Rated
                        </a>

                        <a
                            href="/comments/most-discussed"
                            class="btn btn-light-custom btn-lg"
                        >
                            💬 Most Discussed
                        </a>
                      </div>
                </div>

                <div class="col-lg-5 text-center">
                    <div class="hero-food-card">
                        <div class="food-emoji">🍲</div>

                        <h3>Cook. Share. Enjoy.</h3>

                        <p>
                            Your next favourite recipe is just
                            one click away.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="feature-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">WHAT YOU CAN DO</p>
                <h2>Everything you need in one recipe space</h2>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <a href="/recipes" class="feature-card-link">

                        <div class="feature-card">

                            <div class="feature-icon">🔍</div>

                            <h3>Discover Recipes</h3>

                            <p>
                                Search and filter recipes by category,
                                difficulty, cooking time and rating.
                            </p>

                        </div>

                    </a>
                </div>

                <div class="col-md-4">

                    <% if (currentUser) { %>

                        <a href="/recipes/add" class="feature-card-link">

                    <% } else { %>

                        <a href="/login" class="feature-card-link">

                    <% } %>

                            <div class="feature-card">

                                <div class="feature-icon">📝</div>

                                <h3>Share Your Cooking</h3>

                                <p>
                                    Add ingredients, instructions and an
                                    image to share your homemade recipe.
                                </p>

                            </div>

                        </a>

                </div>

                <div class="col-md-4">
                    <% if (currentUser) { %>
                        <a href="/favourites" class="feature-card-link">
                    <% } else { %>
                        <a href="/login" class="feature-card-link">
                    <% } %>

                        <div class="feature-card">
                            <div class="feature-icon">❤️</div>

                            <h3>Save Your Favourites</h3>

                            <p>
                                Keep recipes that you love in your own
                                personal favourites collection.
                            </p>
                        </div>

                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- SEARCH + FILTER BAR (Oliver's part) -->
    <section class="search-discovery-bar">
        <div class="container">
            <%- include("partials/search-filter-bar", { query: "" }) %>
        </div>
    </section>

    <!-- FEATURED RECIPES (Oliver's part) -->
    <section class="recipe-preview-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">TOP RATED</p>
                <h2>Featured Recipes</h2>
            </div>

            <div class="row g-4">
                <% if (featured.length === 0) { %>
                    <p class="text-center">No featured recipes yet.</p>
                <% } %>
                <% featured.forEach(recipe => { %>
                    <div class="col-md-4">
                        <%- include("partials/recipe-card", { recipe }) %>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>

    <!-- LATEST RECIPES (Oliver's part) -->
    <section class="recipe-preview-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">JUST ADDED</p>
                <h2>Latest Recipes</h2>
            </div>

            <div class="row g-4">
                <% if (latest.length === 0) { %>
                    <p class="text-center">No recipes yet — be the first to add one!</p>
                <% } %>
                <% latest.forEach(recipe => { %>
                    <div class="col-md-4">
                        <%- include("partials/recipe-card", { recipe }) %>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>

    <!-- POPULAR RECIPES (Oliver's part) -->
    <section class="recipe-preview-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">COMMUNITY FAVOURITES</p>
                <h2>Popular Recipes</h2>
            </div>

            <div class="row g-4">
                <% if (popular.length === 0) { %>
                    <p class="text-center">No popular recipes yet.</p>
                <% } %>
                <% popular.forEach(recipe => { %>
                    <div class="col-md-4">
                        <%- include("partials/recipe-card", { recipe }) %>
                    </div>
                <% }) %>
            </div>

            <div class="text-center mt-5">
                <a href="/recipes" class="btn btn-brown">
                    View All Recipes
                </a>
            </div>
        </div>
    </section>
</main>

<%- include("partials/footer") %>