<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="page-section"><div class="container">
  <div class="page-heading-row"><div><h1>Manage Users</h1><p>View and manage registered accounts.</p></div></div>
  <% if (message) { %><div class="alert alert-info"><%= message %></div><% } %>
  <form class="row g-2 mb-4" method="GET" action="/admin/users"><div class="col-md-8"><input class="form-control" name="search" placeholder="Search username or email" value="<%= search %>"></div><div class="col-auto"><button class="btn btn-brown">Search</button></div><div class="col-auto"><a class="btn btn-outline-brown" href="/admin/users">Clear</a></div></form>
  <div class="table-responsive admin-table-card"><table class="table align-middle mb-0"><thead><tr><th>User</th><th>Email</th><th>Role</th><th>Joined</th><th>Actions</th></tr></thead><tbody>
    <% users.forEach(user => { %><tr><td><strong><%= user.username %></strong></td><td><%= user.email %></td><td><span class="role-badge"><%= user.role %></span></td><td><%= user.created_at ? new Date(user.created_at).toLocaleDateString() : '-' %></td><td><a class="btn btn-sm btn-outline-brown" href="/admin/users/<%= user.id %>">View</a></td></tr><% }) %>
    <% if (!users.length) { %><tr><td colspan="5" class="text-center py-4">No users found.</td></tr><% } %>
  </tbody></table></div>
</div></main>
<%- include('../partials/footer') %>
