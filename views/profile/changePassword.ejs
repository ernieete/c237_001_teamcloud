<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="page-section"><div class="container"><div class="form-card mx-auto">
  <h1>Change Password</h1>
  <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <form method="POST" action="/profile/changePassword">
    <div class="mb-3"><label class="form-label">Current Password</label><input class="form-control" type="password" name="currentPassword" required></div>
    <div class="mb-3"><label class="form-label">New Password</label><input class="form-control" type="password" name="newPassword" minlength="8" required></div>
    <div class="mb-4"><label class="form-label">Confirm New Password</label><input class="form-control" type="password" name="confirmPassword" minlength="8" required></div>
    <div class="d-flex gap-2"><button class="btn btn-brown" type="submit">Change Password</button><a class="btn btn-outline-brown" href="/profile">Back</a></div>
  </form>
</div></div></main>
<%- include('../partials/footer') %>
