<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>

<body>

<div class="container mt-5">

    <h1>💬 Most Discussed Recipes</h1>

    <div class="row">

        <% if (recipes.length === 0) { %>

            <p>No comments yet.</p>

        <% } %>

        <% recipes.forEach(recipe => { %>

            <div class="col-md-4 mb-4">

                <div class="card">

                    <% if (recipe.image) { %>

                        <img
                            src="/uploads/<%= recipe.image %>"
                            class="card-img-top"
                            alt="<%= recipe.title %>"
                        >

                    <% } %>

                    <div class="card-body">

                        <h5>
                            <%= recipe.title %>
                        </h5>

                        <p>
                            💬 <%= recipe.totalComments %> comment(s)
                        </p>

                        <a
                            href="/recipes/<%= recipe.id %>"
                            class="btn btn-primary"
                        >
                            View Recipe
                        </a>

                    </div>

                </div>

            </div>

        <% }); %>

    </div>

</div>

</body>
</html>