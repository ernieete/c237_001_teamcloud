<%- include("partials/header") %>
<%- include("partials/navbar") %>

<main>
    <section class="search-discovery-bar">
        <div class="container">
            <%- include("partials/search-filter-bar", { query: "" }) %>
        </div>
    </section>

    <section class="recipe-preview-section">
        <div class="container">
            <div class="section-heading">
                <p class="section-label">FILTERED</p>
                <h2>Filtered Recipes</h2>
            </div>

            <div class="row g-4">
                <% if (results.length === 0) { %>
                    <p class="text-center">No recipes match these filters. Try adjusting them.</p>
                <% } %>
                <% results.forEach(recipe => { %>
                    <div class="col-md-4">
                        <%- include("partials/recipe-card", { recipe }) %>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
</main>

<%- include("partials/footer") %>

